# Copy this file to .env or .secrets and fill in your values.
# .secrets takes precedence over .env if both exist; --env-file overrides both.

SNOWFLAKE_ACCOUNT=myaccount
SNOWFLAKE_USER=myuser
# SNOWFLAKE_ROLE=SYSADMIN
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# --- choose ONE auth method and uncomment its block ---

# 1) externalbrowser (SSO) — no secrets needed beyond the above
# SNOWFLAKE_AUTH_METHOD=externalbrowser

# 2) password
# SNOWFLAKE_AUTH_METHOD=password
# SNOWFLAKE_PASSWORD=mypassword

# 3) keypair
# SNOWFLAKE_AUTH_METHOD=keypair
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=optional-passphrase
